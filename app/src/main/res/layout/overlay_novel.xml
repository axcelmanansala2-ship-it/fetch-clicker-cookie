<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="230dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorOverlayBg"
    android:padding="10dp">

    <TextView
        android:id="@+id/tvOverlayTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📖 Novel Reader"
        android:textColor="@color/colorNovelHeading"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tvOverlayParagraph"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text=""
        android:textColor="@color/colorNovelText"
        android:textSize="11.5sp"
        android:lineSpacingMultiplier="1.3"
        android:maxLines="4"
        android:ellipsize="end"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/tvOverlayProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="@color/colorNovelAccent"
        android:textSize="9.5sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btnOverlayPrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous" />

        <ImageButton
            android:id="@+id/btnOverlayPlayPause"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_play" />

        <ImageButton
            android:id="@+id/btnOverlayNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_next" />

        <View
            android:layout_width="14dp"
            android:layout_height="1dp" />

        <ImageButton
            android:id="@+id/btnOverlayClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_delete" />

    </LinearLayout>

</LinearLayout>
